---
import { getCollection } from 'astro:content';
import { getSections, getSectionNavLabel, isDateSection, isConventionSection } from '../lib/sections';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
}
const { title, description, ogType = 'website' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const siteDesc = 'A research notebook and source index covering the NDP leadership transition following Avi Lewis\'s election as federal NDP leader, March 2026.';
const metaDesc = description || siteDesc;

const all = await getCollection('articles');
const navSections = getSections(all);
const conventionSections = navSections.filter(isConventionSection);
const transitionSections = navSections.filter(s => isDateSection(s) && !isConventionSection(s));
const fixedSections = navSections.filter(s => !isDateSection(s));
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — NDP Transition Research 2026</title>
    <meta name="description" content={metaDesc} />
    <meta property="og:title" content={`${title} — NDP Transition Research 2026`} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={Astro.url} />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <link rel="icon" type="image/svg+xml" href={`${base}assets/logos/favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" />
    <link rel="stylesheet" href={`${base}bennu.css`} />
    <link rel="search" type="application/opensearchdescription+xml" title="NDP Transition Research 2026" href={`${base}pagefind/`} />
    <style>
      /* ─── Site chrome ─── */
      .container { max-width: 960px; margin: 0 auto; padding: 0 28px; }
      .container-narrow { max-width: 760px; margin: 0 auto; padding: 0 28px; }

      header.site {
        background: var(--cream);
        border-bottom: 1.5px solid var(--ink);
        position: sticky; top: 0; z-index: 50;
      }
      header.site .container {
        display: flex; align-items: center; gap: 18px;
        padding-top: 14px; padding-bottom: 14px;
      }
      header.site .home-mark {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; color: var(--ink);
        font-weight: 900; font-size: 15px;
        letter-spacing: -0.01em; line-height: 1.05;
        flex-shrink: 0; max-width: 220px;
      }
      header.site .home-mark .flag {
        width: 10px; height: 28px;
        background: var(--signal);
        border: 1.5px solid var(--ink);
        flex-shrink: 0;
      }
      header.site .home-mark small {
        display: block; font-weight: 500;
        font-size: 10px; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--fg-muted);
        margin-top: 2px;
      }
      header.site nav {
        display: flex; align-items: center;
        gap: 2px; flex-wrap: wrap;
        margin-left: auto;
      }
      header.site nav a,
      header.site nav .dropdown-trigger {
        font-weight: 700; font-size: 13px;
        color: var(--ink); text-decoration: none;
        padding: 8px 12px; border-radius: 999px;
        display: inline-flex; align-items: center; gap: 6px;
        line-height: 1; cursor: pointer; user-select: none; white-space: nowrap;
      }
      header.site nav a:hover,
      header.site nav .dropdown-trigger:hover {
        background: color-mix(in oklab, var(--ink) 8%, transparent);
      }
      header.site nav a.active { background: var(--ink); color: var(--cream); }

      .dropdown { position: relative; }
      .dropdown-trigger .caret { font-size: 10px; opacity: 0.6; }
      .dropdown-menu {
        display: none; position: absolute;
        top: 100%; left: 0;
        background: var(--cream);
        border: 1.5px solid var(--ink);
        border-radius: 14px; min-width: 180px;
        padding: 10px 6px 6px; box-shadow: 0 4px 0 0 var(--ink);
        z-index: 100; flex-direction: column; gap: 2px;
        white-space: nowrap;
      }
      .dropdown:hover .dropdown-menu { display: flex; }
      .dropdown-menu a {
        display: block; width: 100%;
        padding: 8px 14px; font-size: 13px; font-weight: 600;
        color: var(--ink); text-decoration: none;
        border-radius: 999px; white-space: nowrap; line-height: 1.2;
      }
      .dropdown-menu a:hover { background: var(--ink); color: var(--signal); }


      /* ─── Footer ─── */
      footer.site {
        background: var(--ink);
        color: color-mix(in oklab, var(--cream) 85%, transparent);
        margin-top: 80px; padding: 44px 0 40px;
        border-top: 3px solid var(--signal);
      }
      footer.site .container {
        display: grid; grid-template-columns: 1.2fr 1fr;
        gap: 40px; align-items: start;
      }
      footer.site .mark {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 14px;
      }
      footer.site .mark .flag {
        width: 12px; height: 30px;
        background: var(--signal); flex-shrink: 0;
      }
      footer.site .mark strong {
        font-weight: 900; color: var(--cream);
        font-size: 15px; letter-spacing: -0.01em; line-height: 1.1;
      }
      footer.site p {
        font-size: 13px; line-height: 1.55;
        margin: 0 0 10px; max-width: 52ch;
        color: color-mix(in oklab, var(--cream) 85%, transparent);
      }
      footer.site a { color: var(--signal); text-decoration: underline; text-underline-offset: 3px; }
      footer.site .fair-dealing {
        font-size: 11.5px; letter-spacing: 0.02em;
        color: color-mix(in oklab, var(--cream) 55%, var(--ink));
      }
      footer.site .meta {
        font-family: var(--font-mono); font-size: 11px;
        letter-spacing: 0.04em;
        color: color-mix(in oklab, var(--cream) 55%, var(--ink));
      }
      footer.site .meta .row {
        display: flex; justify-content: space-between;
        align-items: baseline; gap: 16px;
        padding: 10px 0;
        border-bottom: 1px solid color-mix(in oklab, var(--cream) 15%, transparent);
        line-height: 1.4;
      }
      footer.site .meta .row:last-child { border-bottom: 0; }
      footer.site .meta .row > span {
        flex: 0 0 auto;
        color: color-mix(in oklab, var(--cream) 55%, var(--ink));
        white-space: nowrap;
      }
      footer.site .meta .row strong {
        color: var(--cream); font-weight: 600;
        text-align: right; word-break: break-word;
        overflow-wrap: anywhere; min-width: 0;
      }

      @media (max-width: 820px) {
        footer.site .container { grid-template-columns: 1fr; }
        header.site nav .dropdown,
        header.site nav a:not(.home-nav-fallback) { display: none; }
        .search-wrap { display: none; }
      }

      /* ─── Command bar trigger ─── */
      #cmd-trigger {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 12px; font-weight: 700;
        font-family: var(--font-body);
        color: var(--fg-muted); background: none;
        border: 1.5px solid color-mix(in oklab, var(--ink) 22%, transparent);
        border-radius: 999px; padding: 5px 11px;
        cursor: pointer; line-height: 1; white-space: nowrap;
        transition: border-color 120ms, color 120ms;
        letter-spacing: 0.01em; position: relative;
      }
      #cmd-trigger:hover { border-color: var(--ink); color: var(--ink); }
      #cmd-trigger svg { flex-shrink: 0; }
      #cmd-trigger .cmd-kbd {
        font-family: var(--font-mono); font-size: 10px; font-weight: 600;
        color: var(--fg-subtle);
        padding: 1px 5px;
        border: 1px solid color-mix(in oklab, var(--ink) 18%, transparent);
        border-radius: 4px; letter-spacing: 0.02em;
        transition: color 120ms, border-color 120ms;
      }
      #cmd-trigger:hover .cmd-kbd { color: var(--fg-muted); border-color: color-mix(in oklab, var(--ink) 35%, transparent); }

      /* ─── First-visit tooltip ─── */
      #cmd-hint {
        position: absolute; top: calc(100% + 10px); right: 0;
        background: var(--ink); color: var(--cream);
        font-size: 12px; font-weight: 600; white-space: nowrap;
        padding: 7px 12px; border-radius: 6px;
        box-shadow: 0 3px 0 0 color-mix(in oklab, var(--ink) 60%, transparent);
        pointer-events: none; z-index: 300;
        opacity: 0; transform: translateY(-4px);
        transition: opacity 200ms, transform 200ms;
      }
      #cmd-hint::before {
        content: ''; position: absolute; bottom: 100%; right: 18px;
        border: 5px solid transparent;
        border-bottom-color: var(--ink);
      }
      #cmd-hint.visible { opacity: 1; transform: translateY(0); }

      /* ─── Command bar modal ─── */
      #cmd-bar {
        position: fixed; inset: 0; z-index: 200;
        display: flex; align-items: flex-start; justify-content: center;
        padding-top: 15vh;
      }
      #cmd-bar[hidden] { display: none; }
      #cmd-backdrop {
        position: absolute; inset: 0;
        background: color-mix(in oklab, var(--ink) 55%, transparent);
      }
      #cmd-panel {
        position: relative; z-index: 1;
        width: 100%; max-width: 560px; margin: 0 24px;
        background: #fff;
        border: 1.5px solid var(--ink);
        border-radius: 0;
        box-shadow: 0 6px 0 0 var(--ink);
        overflow: hidden;
      }
      #cmd-input-row {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 16px;
        border-bottom: 1.5px solid var(--ink);
      }
      #cmd-input {
        flex: 1; border: none; background: none; outline: none;
        font-family: var(--font-body); font-size: 15px;
        color: var(--ink); caret-color: var(--signal-ink);
      }
      #cmd-input::placeholder { color: var(--fg-subtle); }
      #cmd-input-row .cmd-esc {
        font-size: 10px; font-weight: 700;
        letter-spacing: 0.08em; text-transform: uppercase;
        color: var(--fg-muted); padding: 3px 7px;
        border: 1.5px solid color-mix(in oklab, var(--ink) 25%, transparent);
        border-radius: 4px; font-family: var(--font-mono);
      }
      #cmd-list { max-height: 380px; overflow-y: auto; padding: 6px 0; }
      .cmd-group-label {
        font-size: 10px; font-weight: 800;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--fg-subtle); padding: 10px 16px 4px;
      }
      .cmd-item {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 10px 16px; text-decoration: none; color: var(--ink);
        cursor: pointer; font-size: 14px; line-height: 1.2;
      }
      .cmd-item.cmd-active, .cmd-item:hover {
        background: var(--ink); color: #fff;
      }
      .cmd-item-icon {
        flex-shrink: 0; width: 22px; text-align: center;
        font-size: 13px; color: var(--fg-muted); padding-top: 2px;
      }
      .cmd-item.cmd-active .cmd-item-icon,
      .cmd-item:hover .cmd-item-icon { color: var(--signal); }
      .cmd-item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
      .cmd-item-label { font-weight: 700; line-height: 1.3; }
      .cmd-item-desc {
        font-size: 12px; color: var(--fg-muted);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        flex: 1; min-width: 0;
      }
      .cmd-item.cmd-active .cmd-item-desc,
      .cmd-item:hover .cmd-item-desc {
        color: color-mix(in oklab, #fff 70%, var(--ink));
      }
      /* Rich search result items */
      .cmd-item-excerpt {
        font-size: 12px; line-height: 1.45;
        color: var(--fg-muted);
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .cmd-item.cmd-active .cmd-item-excerpt,
      .cmd-item:hover .cmd-item-excerpt { color: color-mix(in oklab, #fff 65%, var(--ink)); }
      .cmd-item-excerpt mark {
        background: #ffe066; color: var(--ink);
        border-radius: 2px; padding: 0 1px;
      }
      .cmd-item.cmd-active .cmd-item-excerpt mark,
      .cmd-item:hover .cmd-item-excerpt mark { background: var(--signal); color: var(--ink); }
      .cmd-outlet-badge {
        display: inline-block; font-size: 10px; font-weight: 800;
        letter-spacing: 0.12em; text-transform: uppercase;
        color: var(--fg-subtle); padding: 2px 7px;
        border: 1px solid color-mix(in oklab, var(--ink) 18%, transparent);
        border-radius: 999px; line-height: 1.4; align-self: flex-start;
      }
      .cmd-item.cmd-active .cmd-outlet-badge,
      .cmd-item:hover .cmd-outlet-badge {
        color: color-mix(in oklab, #fff 60%, var(--ink));
        border-color: color-mix(in oklab, #fff 25%, transparent);
      }
      .cmd-result-count {
        font-size: 11px; font-family: var(--font-mono);
        color: var(--fg-subtle); padding: 6px 16px 2px;
        letter-spacing: 0.04em;
      }
      .cmd-placeholder, .cmd-no-results {
        padding: 10px 16px; font-size: 13px;
        font-style: italic; color: var(--fg-subtle);
      }
      #cmd-footer {
        border-top: 1px solid color-mix(in oklab, var(--ink) 12%, transparent);
        padding: 8px 16px; display: flex; gap: 16px;
        font-size: 11px; color: var(--fg-subtle); font-family: var(--font-mono);
      }
      #cmd-footer kbd {
        font: inherit; padding: 1px 5px;
        border: 1px solid color-mix(in oklab, var(--ink) 22%, transparent);
        border-radius: 3px;
      }
    </style>
  </head>
  <body>
    <header class="site" data-pagefind-ignore>
      <div class="container">
        <a class="home-mark" href={base}>
          <span class="flag" aria-hidden="true"></span>
          <span>
            NDP Transition Research
            <small>2026 · Research notebook</small>
          </span>
        </a>
        <nav>
          {conventionSections.length > 0 && (
            <div class="dropdown">
              <span class="dropdown-trigger">Convention <span class="caret">▾</span></span>
              <div class="dropdown-menu">
                {conventionSections.map(s => (
                  <a href={`${base}${s}/`}>{getSectionNavLabel(s)}</a>
                ))}
              </div>
            </div>
          )}
          {transitionSections.length > 0 && (
            <div class="dropdown">
              <span class="dropdown-trigger">Transition <span class="caret">▾</span></span>
              <div class="dropdown-menu">
                {transitionSections.map(s => (
                  <a href={`${base}${s}/`}>{getSectionNavLabel(s)}</a>
                ))}
              </div>
            </div>
          )}
          {fixedSections.map(s => (
            <a href={`${base}${s}/`}>{getSectionNavLabel(s)}</a>
          ))}
          <button id="cmd-trigger" aria-label="Open command bar (⌘K)">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <circle cx="5.5" cy="5.5" r="4" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8.7" y1="8.7" x2="12" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Search
            <span class="cmd-kbd" aria-hidden="true">⌘K</span>
            <span id="cmd-hint" role="tooltip">Press ⌘K to search anytime</span>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site" data-pagefind-ignore>
      <div class="container">
        <div>
          <div class="mark">
            <span class="flag" aria-hidden="true"></span>
            <strong>NDP Transition<br />Research 2026</strong>
          </div>
          <p class="fair-dealing">
            Contents archived under the Canadian <em>Copyright Act</em> fair dealing provisions (s. 29)
            for research, education, and public-interest purposes. Every file attributes source,
            author, and outlet; links to originals are provided wherever possible. No commercial
            use is made.
          </p>
          <p>
            <a href="https://github.com/barrettsoron/ndp-transition-research-2026">Source on GitHub</a> ·
            Not an official NDP resource.
          </p>
        </div>
        <div class="meta">
          <div class="row"><span>Site</span><strong>Astro 5 · GitHub Pages</strong></div>
          <div class="row"><span>Search</span><strong>Pagefind 1.5</strong></div>
          <div class="row"><span>Maintainer</span><strong>@barrettsoron</strong></div>
        </div>
      </div>
    </footer>

    <!-- Command bar -->
    <div id="cmd-bar" role="dialog" aria-modal="true" aria-label="Command bar" hidden>
      <div id="cmd-backdrop"></div>
      <div id="cmd-panel">
        <div id="cmd-input-row">
          <input id="cmd-input" type="text" placeholder="Search or jump to…" autocomplete="off" spellcheck="false" />
          <span class="cmd-esc">esc</span>
        </div>
        <div id="cmd-list" role="listbox">
          <div>
            <div class="cmd-group-label">Search</div>
            <div id="cmd-search-results"></div>
            <div class="cmd-placeholder">Type to search the archive…</div>
          </div>
          <div class="cmd-group-label">Navigate</div>
          <a class="cmd-item" href={base}>
            <span class="cmd-item-icon">↖</span>
            <span class="cmd-item-label">Home</span>
            <span class="cmd-item-desc">Return to homepage</span>
          </a>
          <a class="cmd-item" href="https://github.com/barrettsoron/ndp-transition-research-2026" target="_blank" rel="noopener">
            <span class="cmd-item-icon">⎇</span>
            <span class="cmd-item-label">GitHub repository</span>
            <span class="cmd-item-desc">View source</span>
          </a>
        </div>
        <div id="cmd-footer">
          <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
          <span><kbd>↵</kbd> open</span>
          <span><kbd>esc</kbd> close</span>
        </div>
      </div>
    </div>

    <script define:vars={{ base }}>
      (function () {
        const bar = document.getElementById('cmd-bar');
        const backdrop = document.getElementById('cmd-backdrop');
        const input = document.getElementById('cmd-input');
        const searchResults = document.getElementById('cmd-search-results');
        const placeholder = bar.querySelector('.cmd-placeholder');
        const trigger = document.getElementById('cmd-trigger');

        let pf = null;
        let activeIdx = -1;

        function allItems() {
          return [...bar.querySelectorAll('.cmd-item:not([hidden])')];
        }

        async function loadPagefind() {
          if (pf) return pf;
          try {
            pf = await import(base + 'pagefind/pagefind.js');
            await pf.init();
            return pf;
          } catch (_) { return null; }
        }

        function open() {
          bar.hidden = false;
          document.body.style.overflow = 'hidden';
          input.value = '';
          activeIdx = -1;
          showPlaceholder();
          requestAnimationFrame(() => input.focus());
        }

        function close() {
          bar.hidden = true;
          document.body.style.overflow = '';
          activeIdx = -1;
        }

        function showPlaceholder() {
          searchResults.replaceChildren();
          placeholder.hidden = false;
        }

        function makeMsg(text) {
          const d = document.createElement('div');
          d.className = 'cmd-no-results';
          d.textContent = text;
          return d;
        }

        function appendExcerpt(container, excerpt) {
          const parts = excerpt.split(/(<mark>|<\/mark>)/);
          let inMark = false;
          parts.forEach(part => {
            if (part === '<mark>') { inMark = true; return; }
            if (part === '</mark>') { inMark = false; return; }
            if (!part) return;
            if (inMark) {
              const m = document.createElement('mark');
              m.textContent = part;
              container.appendChild(m);
            } else {
              container.appendChild(document.createTextNode(part));
            }
          });
        }

        function makeResultItem(url, title, excerpt, outlet) {
          const a = document.createElement('a');
          a.className = 'cmd-item';
          a.href = url;
          const icon = document.createElement('span');
          icon.className = 'cmd-item-icon';
          icon.textContent = '→';
          const body = document.createElement('span');
          body.className = 'cmd-item-body';
          const label = document.createElement('span');
          label.className = 'cmd-item-label';
          label.textContent = title;
          body.appendChild(label);
          if (excerpt) {
            const ex = document.createElement('span');
            ex.className = 'cmd-item-excerpt';
            appendExcerpt(ex, excerpt);
            body.appendChild(ex);
          }
          if (outlet) {
            const badge = document.createElement('span');
            badge.className = 'cmd-outlet-badge';
            badge.textContent = outlet;
            body.appendChild(badge);
          }
          a.append(icon, body);
          return a;
        }

        async function search(q) {
          if (!q.trim()) { showPlaceholder(); return; }
          placeholder.hidden = true;
          searchResults.replaceChildren();
          const engine = await loadPagefind();
          if (!engine) {
            searchResults.appendChild(makeMsg('Search unavailable in dev — run pnpm build first'));
            return;
          }
          const res = await engine.search(q);
          const data = await Promise.all(res.results.slice(0, 8).map(r => r.data()));
          if (!data.length) {
            searchResults.appendChild(makeMsg('No results'));
            return;
          }
          const count = document.createElement('div');
          count.className = 'cmd-result-count';
          count.textContent = `${res.results.length} result${res.results.length === 1 ? '' : 's'}`;
          const frag = document.createDocumentFragment();
          frag.appendChild(count);
          data.forEach(d => frag.appendChild(makeResultItem(d.url, d.meta?.title ?? d.url, d.excerpt ?? '', d.meta?.outlet ?? '')));
          searchResults.appendChild(frag);
        }

        function setActive(idx) {
          const items = allItems();
          items.forEach((el, i) => el.classList.toggle('cmd-active', i === idx));
          activeIdx = idx;
          if (idx >= 0) items[idx]?.scrollIntoView({ block: 'nearest' });
        }

        input.addEventListener('input', () => { activeIdx = -1; search(input.value); });

        input.addEventListener('keydown', e => {
          const items = allItems();
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            setActive(Math.min(activeIdx + 1, items.length - 1));
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            setActive(Math.max(activeIdx - 1, -1));
          } else if (e.key === 'Enter' && activeIdx >= 0) {
            e.preventDefault();
            items[activeIdx]?.click();
          } else if (e.key === 'Escape') {
            close();
          }
        });

        backdrop.addEventListener('click', close);
        trigger?.addEventListener('click', open);

        // First-visit hint
        const hint = document.getElementById('cmd-hint');
        if (hint && !localStorage.getItem('cmd-hint-seen')) {
          setTimeout(() => { hint.classList.add('visible'); }, 1200);
          setTimeout(() => { hint.classList.remove('visible'); }, 5500);
          trigger?.addEventListener('click', () => {
            hint.classList.remove('visible');
            localStorage.setItem('cmd-hint-seen', '1');
          }, { once: true });
          document.addEventListener('keydown', e => {
            if ((e.metaKey || e.ctrlKey || e.altKey) && (e.key === 'k' || e.key === 'K')) {
              hint.classList.remove('visible');
              localStorage.setItem('cmd-hint-seen', '1');
            }
          }, { once: true });
        }

        document.addEventListener('keydown', e => {
          const k = e.key === 'k' || e.key === 'K';
          if (k && (e.metaKey || e.ctrlKey || e.altKey)) {
            e.preventDefault();
            bar.hidden ? open() : close();
          }
          if (e.key === 'Escape' && !bar.hidden) close();
        });
      })();
    </script>
  </body>
</html>
