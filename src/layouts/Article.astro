---
import Base from './Base.astro';
import Search from '../components/Search.astro';
import { getSectionLabel, isConventionSection, isDateSection } from '../lib/sections';

interface Props {
  title: string;
  date: Date;
  author?: string;
  outlet?: string;
  source?: string;
  language?: string;
  type?: string;
  speakers?: string[];
  video?: string;
  note?: string;
  stub?: boolean;
  section?: string;
  prevArticle?: { title: string; href: string };
  nextArticle?: { title: string; href: string };
}
const { title, date, author, outlet, source, language, type, speakers, video, note, stub, section, prevArticle, nextArticle } = Astro.props;
const dateStr = date.toLocaleDateString('en-CA', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const sectionLabel = section ? getSectionLabel(section) : null;
const groupLabel = section ? (isConventionSection(section) ? 'Convention' : isDateSection(section) ? 'Transition' : null) : null;

const ogDesc = note || (outlet ? `${outlet} · ${dateStr}` : dateStr);
const lang = language ?? 'en';
---
<Base title={title} description={ogDesc} ogType="article">
  <Search slot="search" />
  <style>
    .article-page { padding: 40px 0 0; }
    .prose-wrap { max-width: 680px; }

    /* Breadcrumb */
    .breadcrumb {
      font-size: 12px; font-weight: 600;
      color: var(--fg-muted); letter-spacing: 0.02em;
      margin-bottom: 20px;
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .breadcrumb a { color: var(--fg-muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--signal-ink); }
    .breadcrumb .sep { color: var(--signal); font-weight: 800; }

    /* Article head */
    .article-head { margin-bottom: 36px; }
    .article-head .kicker {
      display: inline-flex; align-items: center; gap: 8px;
      font-weight: 800; font-size: 11px;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--signal-ink); margin-bottom: 18px;
    }
    .article-head .kicker::before {
      content: ""; width: 18px; height: 2px; background: var(--signal);
    }
    .article-head h1 {
      font-weight: 900;
      font-size: clamp(30px, 3.6vw, 44px);
      line-height: 1.05; letter-spacing: -0.025em;
      margin: 0 0 18px; max-width: 22ch; text-wrap: balance;
    }
    .article-head .standfirst {
      font-weight: 500; font-size: 18px;
      line-height: 1.45; color: var(--fg);
      margin: 0 0 24px; max-width: 62ch;
    }
    .byline-row {
      display: flex; flex-wrap: wrap;
      align-items: center; gap: 10px 18px;
      padding: 14px 0;
      border-top: 1.5px solid var(--ink);
      border-bottom: 1.5px solid var(--ink);
      font-size: 13px;
    }
    .byline-row .by { font-weight: 700; color: var(--ink); }
    .byline-row .outlet { font-weight: 700; color: var(--ink); }
    .byline-row .sep { color: var(--signal); font-weight: 900; }
    .byline-row .date {
      font-family: var(--font-mono); font-size: 12px;
      color: var(--fg-muted); letter-spacing: 0.02em;
    }
    .byline-row .badge {
      font-weight: 800; font-size: 10px;
      letter-spacing: 0.14em; text-transform: uppercase;
      padding: 3px 9px 2px; border: 1.5px solid var(--ink);
      border-radius: 999px; line-height: 1;
    }
    .byline-row .badge.fr { background: var(--cream-2); }
    .byline-row .badge.en-fr { background: var(--cream-2); }
    .source-link {
      margin-left: auto; font-weight: 800; font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--signal-ink); text-decoration: none;
      display: inline-flex; align-items: center; gap: 6px;
      border-bottom: 1.5px solid var(--signal); padding-bottom: 1px;
    }
    .source-link:hover { color: var(--ink); border-color: var(--ink); }

    /* Note block */
    .note-block {
      margin-top: 20px; padding: 14px 18px;
      background: var(--cream-2); border-left: 3px solid var(--signal);
      font-size: 13.5px; line-height: 1.5; color: var(--fg);
      border-radius: 0 4px 4px 0;
    }
    .note-block strong {
      font-weight: 800; text-transform: uppercase;
      font-size: 10.5px; letter-spacing: 0.18em;
      color: var(--signal-ink); display: block; margin-bottom: 4px;
    }

    /* Stub block */
    .stub-block {
      background: var(--hope); border: 1.5px solid var(--ink);
      border-radius: 4px; padding: 18px 22px; margin: 24px 0;
      font-size: 14px; line-height: 1.5; color: var(--ink);
      display: grid; grid-template-columns: auto 1fr auto;
      gap: 16px; align-items: center;
    }
    .stub-block .icon {
      width: 36px; height: 36px; background: var(--ink);
      color: var(--hope); display: inline-flex;
      align-items: center; justify-content: center;
      font-weight: 900; font-size: 18px; flex-shrink: 0;
    }
    .stub-block strong {
      display: block; font-weight: 800; font-size: 11px;
      letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 2px;
    }
    .stub-block a {
      color: var(--ink); font-weight: 800; font-size: 11px;
      letter-spacing: 0.14em; text-transform: uppercase;
      text-decoration: none; border: 1.5px solid var(--ink);
      padding: 8px 14px 7px; border-radius: 999px;
      background: var(--cream); white-space: nowrap;
    }
    .stub-block a:hover { background: var(--ink); color: var(--hope); }

    /* Prose */
    .prose {
      font-weight: 400; font-size: 17.5px;
      line-height: 1.65; color: var(--ink);
    }
    .prose :global(p) { margin: 0 0 1.1em; max-width: none; }
    .prose :global(h2) {
      font-weight: 900; font-size: 24px; line-height: 1.15;
      letter-spacing: -0.015em; margin: 2.2em 0 0.5em;
      padding-top: 1.2em;
      border-top: 1.5px solid color-mix(in oklab, var(--ink) 20%, transparent);
    }
    .prose :global(h3) {
      font-weight: 800; font-size: 18px; line-height: 1.2;
      letter-spacing: -0.01em; margin: 1.8em 0 0.4em;
    }
    .prose :global(blockquote) {
      margin: 1.6em 0; padding: 18px 24px;
      border-left: 4px solid var(--signal);
      background: var(--cream-2); font-weight: 500;
      font-size: 18.5px; line-height: 1.45;
      color: var(--ink); font-style: normal; max-width: none;
    }
    .prose :global(blockquote p) { margin: 0 0 0.8em; }
    .prose :global(blockquote p:last-child) { margin-bottom: 0; }
    .prose :global(blockquote cite) {
      display: block; margin-top: 10px;
      font-size: 12px; font-weight: 700; font-style: normal;
      letter-spacing: 0.04em; color: var(--fg-muted);
    }
    .prose :global(blockquote cite::before) { content: "— "; color: var(--signal-ink); }
    .prose :global(hr) {
      border: 0; height: 1.5px;
      background: var(--ink); margin: 2em 0; max-width: 120px;
    }
    .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2em 1.4em; padding: 0; }
    .prose :global(li) { margin-bottom: 0.4em; }
    .prose :global(a) {
      color: var(--signal-ink); text-decoration: underline;
      text-decoration-thickness: 1.5px; text-underline-offset: 3px;
    }
    .prose :global(a:hover) { background: var(--signal); color: var(--ink); text-decoration: none; }
    .prose :global(strong) { font-weight: 700; }
    .prose :global(table) { border-collapse: collapse; width: 100%; margin: 1.5em 0; font-size: 15px; }
    .prose :global(th) { font-weight: 800; text-align: left; border-bottom: 2px solid var(--ink); padding: 8px 12px; }
    .prose :global(td) { padding: 8px 12px; border-bottom: 1px solid color-mix(in oklab, var(--ink) 15%, transparent); }

    /* Speakers / video */
    .speakers-note, .video-link {
      font-size: 13px; color: var(--fg-muted); margin-top: 1rem;
    }
    .video-link a { color: var(--signal-ink); }

    /* Article footer nav */
    .article-foot {
      margin-top: 56px; padding: 28px 0 0;
      border-top: 1.5px solid var(--ink);
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .nav-card {
      display: block; padding: 16px 18px;
      border: 1.5px solid var(--ink); border-radius: 8px;
      text-decoration: none; color: var(--ink);
      background: var(--white);
      transition: transform 140ms var(--ease-out), box-shadow 140ms var(--ease-out);
    }
    .nav-card:hover { transform: translateY(-2px); box-shadow: 0 4px 0 0 var(--ink); }
    .nav-card .dir {
      font-weight: 800; font-size: 10px;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--signal-ink); margin-bottom: 6px;
    }
    .nav-card.next { text-align: right; }
    .nav-card .t { font-weight: 700; font-size: 14px; line-height: 1.3; }

    @media (max-width: 820px) {
      .article-foot { grid-template-columns: 1fr; }
      .stub-block { grid-template-columns: auto 1fr; }
      .stub-block a { grid-column: 1 / -1; justify-self: start; }
    }
  </style>

  <section class="article-page">
    <div class="container">
      <div class="prose-wrap">

        <nav class="breadcrumb" data-pagefind-ignore>
          <a href={base}>Home</a>
          {groupLabel && (
            <>
              <span class="sep">→</span>
              <span>{groupLabel}</span>
            </>
          )}
          {sectionLabel && section && (
            <>
              <span class="sep">→</span>
              <a href={`${base}${section}/`}>{sectionLabel}</a>
            </>
          )}
          <span class="sep">→</span>
          <span>{title.length > 55 ? title.slice(0, 55) + '…' : title}</span>
        </nav>

        <header class="article-head">
          {(outlet || type) && (
            <div class="kicker">
              {outlet}{outlet && type && type !== 'article' ? ' · ' : ''}{type && type !== 'article' ? type : ''}
            </div>
          )}
          <h1>{title}</h1>
          {!stub && note && <p class="standfirst">{note}</p>}
          <div class="byline-row">
            {author && <span class="by">By {author}</span>}
            {author && outlet && <span class="sep">·</span>}
            {outlet && <span class="outlet" data-pagefind-meta="outlet">{outlet}</span>}
            {(author || outlet) && <span class="sep">·</span>}
            <time class="date">{dateStr}</time>
            {lang !== 'en' && <span class={`badge ${lang}`}>{lang.toUpperCase()}</span>}
            {type && type !== 'article' && <span class="badge">{type}</span>}
            {source && <a class="source-link" href={source} target="_blank" rel="noopener">Original source ↗</a>}
          </div>
          {!stub && !note && speakers && speakers.length > 0 && (
            <div class="note-block">
              <strong>Speakers</strong>
              {speakers.join(', ')}
            </div>
          )}
        </header>

        {stub ? (
          <div class="stub-block">
            <span class="icon" aria-hidden="true">!</span>
            <div>
              <strong>Full text not archived</strong>
              {source
                ? `This article is behind a paywall or otherwise unavailable. Metadata and headline preserved for reference.`
                : `Full text not yet available. Metadata preserved for reference.`
              }
            </div>
            {source && <a href={source} target="_blank" rel="noopener">Read the original ↗</a>}
          </div>
        ) : (
          <>
            {note && (
              <div class="note-block">
                <strong>Note</strong>
                {note}
              </div>
            )}
            <article class="prose">
              <slot />
            </article>
            {speakers && speakers.length > 0 && !note && (
              <div class="speakers-note">Speakers: {speakers.join(', ')}</div>
            )}
            {video && (
              <div class="video-link"><a href={video} target="_blank" rel="noopener">Video recording →</a></div>
            )}
            {(type === 'article' || type === 'statement') && source && (
              <aside class="research-notice">
                <p><strong>Research notice:</strong> This article is reproduced in a personal research notebook for the purpose of research and criticism (<em>Copyright Act</em>, ss. 29 / 29.1). Please read the original at <a href={source} target="_blank" rel="noopener">{source}</a>. Copyright remains with the original publisher.</p>
              </aside>
            )}
            {type === 'transcript' && (
              <aside class="research-notice">
                <p><strong>Research notice:</strong> This transcript is reproduced in a personal research notebook for the purpose of research and criticism (<em>Copyright Act</em>, ss. 29 / 29.1). The original broadcast is the authoritative version — where possible, watch it at its source. Copyright remains with the original broadcaster.</p>
              </aside>
            )}
          </>
        )}

        {(prevArticle || nextArticle) && (
          <div class="article-foot">
            {prevArticle ? (
              <a class="nav-card prev" href={prevArticle.href}>
                <div class="dir">← Previous in section</div>
                <div class="t">{prevArticle.title}</div>
              </a>
            ) : <div />}
            {nextArticle && (
              <a class="nav-card next" href={nextArticle.href}>
                <div class="dir">Next in section →</div>
                <div class="t">{nextArticle.title}</div>
              </a>
            )}
          </div>
        )}

      </div>
    </div>
  </section>
</Base>
