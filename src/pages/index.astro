---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.astro';
import { getCollection } from 'astro:content';
import { getSections, getSectionLabel, getSectionDescription, isConventionSection, isDateSection } from '../lib/sections';

const all = await getCollection('articles');
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const sectionSlugs = getSections(all);

const countBySection = Object.fromEntries(
  sectionSlugs.map(s => [
    s,
    all.filter(a => a.id.startsWith(`${s}/`) && !a.data.stub).length,
  ])
);

// Stat counts for hero
const totalArticles = all.filter(a => !a.data.stub && (!a.data.type || a.data.type === 'article')).length;
const totalSpeeches = all.filter(a => a.data.type === 'speech').length;
const datesSlugs = sectionSlugs.filter(s => isDateSection(s));
const daysCovered = datesSlugs.length;
const allLanguages = new Set(all.map(a => a.data.language ?? 'en'));
const languageCount = allLanguages.size;

// Section groupings
const conventionSlugs = sectionSlugs.filter(isConventionSection);
const transitionSlugs = sectionSlugs.filter(s => isDateSection(s) && !isConventionSection(s));
const fixedSlugs = sectionSlugs.filter(s => !isDateSection(s));

const featuredSlug = sectionSlugs.includes('march-29') ? 'march-29' : null;
const nonFeaturedConvention = conventionSlugs.filter(s => s !== featuredSlug);
---
<Base title="Home">
  <Search slot="search" />
  <style>
    /* ─── Hero ─── */
    .hero-home {
      padding: 64px 0 56px;
      border-bottom: 1.5px solid var(--ink);
    }
    .hero-home .eyebrow {
      display: inline-block;
      font-weight: 800; font-size: 11px;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--signal-ink); margin-bottom: 20px;
    }
    .hero-home .eyebrow::before {
      content: "";
      display: inline-block; width: 22px; height: 2px;
      background: var(--signal); vertical-align: middle;
      margin-right: 10px; margin-bottom: 2px;
    }
    .hero-home h1 {
      font-weight: 800;
      font-size: clamp(28px, 3.5vw, 46px);
      line-height: 1.1; letter-spacing: -0.02em;
      margin: 0 0 24px; text-wrap: balance; max-width: 34ch;
    }
    .hero-home h1 em {
      font-style: normal;
      color: var(--signal-ink);
    }
    .hero-home .lede {
      font-weight: 400;
      font-size: clamp(16px, 1.3vw, 18px);
      line-height: 1.55; max-width: 58ch;
      margin: 0 0 28px; color: var(--fg);
    }
    .hero-home .lede a { color: var(--link); }
    .scope-facts {
      display: flex; flex-wrap: wrap;
      gap: 28px 44px; padding-top: 22px;
      border-top: 1.5px solid var(--ink); max-width: 720px;
    }
    .scope-facts .fact { font-family: var(--font-body); }
    .scope-facts .num {
      font-weight: 900; font-size: 32px; line-height: 1;
      color: var(--ink); letter-spacing: -0.02em;
      display: block; margin-bottom: 4px;
    }
    .scope-facts .lbl {
      font-size: 11px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--fg-muted);
    }
    .win-note {
      font-size: 12px; font-weight: 600;
      letter-spacing: 0.04em; color: var(--fg-muted);
      padding-top: 18px; max-width: 720px;
      display: flex; flex-wrap: wrap; gap: 6px 20px;
      align-items: center;
    }
    .win-note .sep { color: var(--rule); }
    .archive-stats {
      display: flex; flex-wrap: wrap; gap: 20px 36px;
      padding-top: 18px;
      border-top: 1px solid var(--rule);
      max-width: 720px;
    }
    .archive-stats .fact { font-family: var(--font-body); }
    .archive-stats .num {
      font-weight: 800; font-size: 20px; line-height: 1;
      color: var(--fg-muted); letter-spacing: -0.01em;
      display: block; margin-bottom: 3px;
    }
    .archive-stats .lbl {
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--fg-subtle);
    }

    /* ─── Section index ─── */
    .sections-index { padding: 64px 0 8px; }
    .sections-index .index-head {
      display: flex; align-items: end;
      justify-content: space-between;
      gap: 24px; flex-wrap: wrap; margin-bottom: 28px;
    }
    .sections-index h2 {
      font-weight: 900;
      font-size: clamp(24px, 2.5vw, 30px);
      line-height: 1.1; letter-spacing: -0.02em; margin: 0;
    }
    .sections-index .index-head .help {
      font-size: 13px; color: var(--fg-muted);
      max-width: 44ch; margin: 0;
    }

    .group-label {
      font-weight: 800; font-size: 10.5px;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--signal-ink); padding: 18px 0 12px;
      margin-top: 20px; border-top: 1.5px solid var(--ink);
      display: flex; align-items: center; gap: 10px;
    }
    .group-label:first-of-type { margin-top: 0; border-top: 0; padding-top: 0; }
    .group-label .dash { flex: 0 0 24px; height: 3px; background: var(--signal); }

    .section-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px;
    }
    .section-card {
      display: flex; flex-direction: column;
      justify-content: space-between; gap: 16px;
      padding: 18px 20px; background: var(--white);
      border: 1.5px solid var(--ink); border-radius: 8px;
      text-decoration: none; color: var(--ink); min-height: 108px;
      transition: transform 140ms var(--ease-out), box-shadow 140ms var(--ease-out);
    }
    .section-card:hover { transform: translateY(-2px); box-shadow: 0 4px 0 0 var(--ink); }
    .section-card .title {
      font-weight: 800; font-size: 17px;
      line-height: 1.15; letter-spacing: -0.01em; color: var(--ink);
    }
    .section-card .desc {
      font-size: 12.5px; line-height: 1.4;
      color: var(--fg-muted); margin-top: 2px;
    }
    .section-card .foot {
      display: flex; align-items: center;
      justify-content: space-between;
      font-family: var(--font-mono); font-size: 11px;
      font-weight: 500; color: var(--fg-muted); letter-spacing: 0.02em;
    }
    .section-card .count {
      background: var(--cream); border: 1.5px solid var(--ink);
      color: var(--ink); border-radius: 999px;
      padding: 3px 9px 2px; font-weight: 800; font-size: 11px;
      letter-spacing: 0.04em;
    }
    .section-card .arrow { color: var(--signal-ink); font-weight: 800; }
    .section-card:hover .arrow { color: var(--ink); }

    /* Featured card */
    .section-card.featured {
      grid-column: span 3; flex-direction: row;
      align-items: stretch; padding: 24px 28px; margin-top: 14px;
      background: var(--ink); color: var(--cream);
      border-color: var(--ink);
    }
    .section-card.featured:hover { box-shadow: 0 4px 0 0 var(--signal); }
    .section-card.featured .f-copy {
      flex: 1; display: flex; flex-direction: column; gap: 6px;
    }
    .section-card.featured .eyebrow {
      font-weight: 800; font-size: 10.5px;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--signal); margin-bottom: 4px;
    }
    .section-card.featured .title { font-size: 22px; color: var(--cream); font-weight: 900; letter-spacing: -0.02em; }
    .section-card.featured .desc { color: color-mix(in oklab, var(--cream) 75%, var(--ink)); font-size: 13px; max-width: 56ch; }
    .section-card.featured .f-meta {
      display: flex; align-items: center; gap: 14px;
      padding-left: 24px;
      border-left: 1.5px solid color-mix(in oklab, var(--cream) 25%, var(--ink));
      flex-shrink: 0; align-self: center;
    }
    .section-card.featured .f-meta .count { background: var(--signal); border-color: var(--signal); color: var(--ink); font-size: 13px; padding: 6px 14px 5px; }
    .section-card.featured .arrow { color: var(--signal); font-size: 18px; }

    @media (max-width: 820px) {
      .section-grid { grid-template-columns: repeat(2, 1fr); }
      .section-card.featured { flex-direction: column; }
      .section-card.featured .f-meta {
        padding-left: 0; border-left: 0;
        border-top: 1.5px solid color-mix(in oklab, var(--cream) 25%, var(--ink));
        padding-top: 16px; justify-content: space-between;
      }
    }
    @media (max-width: 560px) {
      .section-grid { grid-template-columns: 1fr; }
      .scope-facts { gap: 20px 32px; }
      .scope-facts .num { font-size: 24px; }
    }
  </style>

  <section class="hero-home">
    <div class="container">
      <div class="eyebrow">Public archive · Fair dealing s.29</div>
      <h1>Coverage of the <em>NDP&nbsp;transition</em> as it was written.</h1>
      <p class="lede">
        A primary-source archive of news coverage, speeches, transcripts, and statements from the
        NDP leadership transition following Avi Lewis's election as federal NDP leader at the Winnipeg
        convention, March 27–29, 2026. Maintained by <a href="https://github.com/barrettsoron">@barrettsoron</a>.
      </p>
      <div class="scope-facts">
        <div class="fact"><span class="num">56%</span><span class="lbl">First ballot</span></div>
        <div class="fact"><span class="num">39,734</span><span class="lbl">Votes for Lewis</span></div>
        <div class="fact"><span class="num">70.6%</span><span class="lbl">Voter turnout</span></div>
        <div class="fact"><span class="num">$1.5M</span><span class="lbl">Most raised in NDP history</span></div>
      </div>
      <div class="win-note">
        <span>Memberships sold in 338 of 343 ridings</span>
        <span class="sep">·</span>
        <span>Every province &amp; territory</span>
        <span class="sep">·</span>
        <span>11,000+ donors</span>
      </div>
      <div class="archive-stats">
        {totalArticles > 0 && <div class="fact"><span class="num">{totalArticles}</span><span class="lbl">Articles archived</span></div>}
        {totalSpeeches > 0 && <div class="fact"><span class="num">{totalSpeeches}</span><span class="lbl">Speeches</span></div>}
        <div class="fact"><span class="num">{daysCovered}</span><span class="lbl">Days covered</span></div>
        {languageCount > 1 && <div class="fact"><span class="num">{languageCount}</span><span class="lbl">Languages</span></div>}
      </div>
    </div>
  </section>

  <section class="sections-index">
    <div class="container">
      <div class="index-head">
        <h2>Browse the archive</h2>
        <p class="help">Dated folders follow the news cycle. Fixed sections collect primary texts and historical context.</p>
      </div>

      {(nonFeaturedConvention.length > 0 || featuredSlug) && (
        <>
          <div class="group-label"><span class="dash"></span> Convention · Mar 26–29</div>
          {nonFeaturedConvention.length > 0 && (
            <div class="section-grid">
              {nonFeaturedConvention.map(s => (
                <a class="section-card" href={`${base}${s}/`}>
                  <div>
                    <div class="title">{getSectionLabel(s)}</div>
                    <div class="desc">{getSectionDescription(s)}</div>
                  </div>
                  <div class="foot">
                    <span class="count">{countBySection[s]}</span>
                    <span class="arrow">→</span>
                  </div>
                </a>
              ))}
            </div>
          )}
          {featuredSlug && (
            <a class="section-card featured" href={`${base}${featuredSlug}/`}>
              <div class="f-copy">
                <div class="eyebrow">Convention day</div>
                <div class="title">{getSectionLabel(featuredSlug)}</div>
                <div class="desc">{getSectionDescription(featuredSlug)}</div>
              </div>
              <div class="f-meta">
                <span class="count">{countBySection[featuredSlug]} {countBySection[featuredSlug] === 1 ? 'item' : 'items'}</span>
                <span class="arrow">→</span>
              </div>
            </a>
          )}
        </>
      )}

      {transitionSlugs.length > 0 && (
        <>
          <div class="group-label"><span class="dash"></span> Transition · Mar 30 onward</div>
          <div class="section-grid">
            {transitionSlugs.map(s => (
              <a class="section-card" href={`${base}${s}/`}>
                <div>
                  <div class="title">{getSectionLabel(s)}</div>
                  <div class="desc">{getSectionDescription(s)}</div>
                </div>
                <div class="foot">
                  <span class="count">{countBySection[s]}</span>
                  <span class="arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {fixedSlugs.length > 0 && (
        <>
          <div class="group-label"><span class="dash"></span> Primary sources &amp; legacy</div>
          <div class="section-grid">
            {fixedSlugs.map(s => (
              <a class="section-card" href={`${base}${s}/`}>
                <div>
                  <div class="title">{getSectionLabel(s)}</div>
                  <div class="desc">{getSectionDescription(s)}</div>
                </div>
                <div class="foot">
                  <span class="count">{countBySection[s]}</span>
                  <span class="arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</Base>
